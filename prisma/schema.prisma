generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum MembershipTier {
  FREE
  BASIC
  MEMORABLE
  ELITE
}

enum SubscriptionStatus {
  NONE
  ACTIVE
  CANCEL_AT_PERIOD_END
  CANCELED
}

enum MentalGameTopic {
  SLUMP
  CONFIDENCE
  NERVES
  FEAR_OF_FAILURE
  PRESSURE_SITUATIONS
  LOSING_MOTIVATION
  OTHER
}

enum MentalGameResponsePreference {
  VIDEO_RESPONSE
  WRITTEN_RESPONSE
}

enum MentalGameSubmissionStatus {
  PENDING
  REVIEWING
  COMPLETED
}

model User {
  id                     String                 @id @default(cuid())
  name                   String?
  email                  String                 @unique
  password               String
  signupDate             DateTime               @default(now())
  onboardingEmail1Sent   Boolean                @default(false)
  onboardingEmail2Sent   Boolean                @default(false)
  onboardingEmail3Sent   Boolean                @default(false)
  freeSubmissionUsed     Boolean                @default(false)
  coachingSubmissionsUsedThisMonth Int          @default(0)
  coachingSubmissionPeriod         String?
  eliteRolloverCredits             Int          @default(0)
  assessmentCallBooked             Boolean      @default(false)
  assessmentCallDate               DateTime?
  membershipTier         MembershipTier         @default(FREE)
  subscriptionStatus     SubscriptionStatus     @default(ACTIVE)
  stripeCustomerId       String?                @unique
  stripeSubscriptionId   String?                @unique
  stripePriceId          String?
  subscriptionCurrentPeriodEnd DateTime?
  subscriptionCancelAtPeriodEnd Boolean         @default(false)
  position               String?
  age                    Int?
  graduationYear         Int?
  currentTeam            String?
  level                  String?
  playerBio              String?
  notifySubmissionResponse Boolean              @default(true)
  notifyGoalResponse       Boolean              @default(true)
  notifyWeeklyCheckin      Boolean              @default(true)
  notifyAnnouncements      Boolean              @default(true)
  emailVerified          DateTime?
  image                  String?
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt
  accounts               Account[]
  sessions               Session[]
  mentalGameSubmissions  MentalGameSubmission[]
  swingAnalysisSubmissions SwingAnalysisSubmission[]
  goalCheckins           GoalCheckin[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model MentalGameSubmission {
  id                 String                       @id @default(cuid())
  userId             String
  userEmail          String
  playerName         String
  playerAge          String
  topic              MentalGameTopic
  message            String
  videoPath          String?
  responsePreference MentalGameResponsePreference
  status             MentalGameSubmissionStatus   @default(PENDING)
  responseText       String?
  responseVideoUrl   String?
  memberVimeoLink    String?
  respondedAt        DateTime?
  createdAt          DateTime                     @default(now())
  updatedAt          DateTime                     @updatedAt
  user               User                         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model SwingAnalysisSubmission {
  id                 String                       @id @default(cuid())
  userId             String
  userEmail          String
  playerName         String
  pitchType          String
  handedness         String
  notes              String
  submittedVideo     String
  responsePreference MentalGameResponsePreference
  status             MentalGameSubmissionStatus   @default(PENDING)
  responseText       String?
  responseVideoUrl   String?
  memberVimeoLink    String?
  respondedAt        DateTime?
  createdAt          DateTime                     @default(now())
  updatedAt          DateTime                     @updatedAt
  user               User                         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model GoalCheckin {
  id                Int        @id @default(autoincrement())
  userId            String
  user              User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  monthlyFocus      String
  lastMonthReview   String
  focusArea         String
  additionalNotes   String?
  coachResponse     String?
  status            String     @default("pending")
  createdAt         DateTime   @default(now())
  respondedAt       DateTime?
  goals             GoalItem[]

  @@index([userId])
  @@index([userId, createdAt])
}

model GoalItem {
  id           Int         @id @default(autoincrement())
  checkinId    Int
  checkin      GoalCheckin @relation(fields: [checkinId], references: [id], onDelete: Cascade)
  category     String
  description  String
  targetValue  String?
  completed    Boolean     @default(false)
  completedAt  DateTime?
  createdAt    DateTime    @default(now())

  @@index([checkinId])
}

